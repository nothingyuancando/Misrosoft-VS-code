{
  "name": "misrosoft-vs-code",
  "displayName": "Misrosoft VS Code Guardian",
  "description": "在 VS Code 里运行的代码文件守护小游戏。",
  "version": "0.1.0",
  "publisher": "nothingyuancando",
  "scripts": {
    "start": "node scripts/start.js",
    "package": "npx @vscode/vsce package --no-dependencies",
    "install-local": "npm run package && code --install-extension misrosoft-vs-code-0.1.0.vsix --force"
  },
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:misrosoftVsCode.startGuardian"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "misrosoftVsCode.startGuardian",
        "title": "微软大战代码：守护你的代码文件"
      }
    ]
  }
}
